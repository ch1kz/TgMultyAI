TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telegram_api_hash_here

# Preferred: JSON account registry managed by `python tg_multyai.py accounts ...`.
ALICE_ACCOUNTS_FILE=tg_multyai_accounts.json

# Optional fallback/override: comma-separated local Telethon session names.
ALICE_ACCOUNTS=acc1, acc2, acc3, acc4, acc5, acc6

# ID works only if the bot entity is already known to the Telegram session.
# If a fresh account cannot resolve the ID, pass the bot username via --bot / ALICE_BOT.
ALICE_BOT=@alice_ya_bot

ALICE_SESSIONS_DIR=sessions
ALICE_REQUEST_TIMEOUT=120
ALICE_ANSWER_IDLE_TIMEOUT=4.0
ALICE_RESET_TIMEOUT=15
ALICE_TELEGRAM_MESSAGE_LIMIT=4096

# ALICE_ALLOWED_FILE_ROOTS=C:\Users\Dev\Documents

# Optional CORS. Disabled by default. When enabled without explicit origins,
# localhost/127.0.0.1 origins are allowed.
# ALICE_CORS=true
# ALICE_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Optional Telegram MTProto proxy for Telethon sessions.
# Supported schemes: socks5, socks4, http. Prefer IPv4 SOCKS5.
# ALICE_TELEGRAM_PROXY is only a fallback for accounts without a specific proxy.
# ALICE_TELEGRAM_PROXY=socks5://user:password@proxy.example.com:1080
#
# Recommended: assign proxies per account. You may reuse one proxy for 1-3 accounts.
# Separate entries with semicolons or new lines.
# ALICE_TELEGRAM_PROXIES=acc1=socks5://user1:pass1@proxy1.example.com:1080;acc2=socks5://user1:pass1@proxy1.example.com:1080;acc3=socks5://user2:pass2@proxy2.example.com:1080

# Optional: add extra service/noise message regexes separated by |
# ALICE_SERVICE_PATTERNS=^пример служебного текста$|^еще один шаблон
